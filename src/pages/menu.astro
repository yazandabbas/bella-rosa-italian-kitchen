---
import SiteLayout from "../layouts/SiteLayout.astro";
import { menuItems, restaurant } from "../data/site";
---

<SiteLayout
  title="Menu | Bella Rosa Italian Kitchen"
  description="Browse Bella Rosa's seasonal Italian menu with prices, descriptions, and dietary labels."
>
  <main class="menu-page">
    <section class="menu-hero">
      <img src="/assets/generated/bella-menu-cover.png" alt="Bella Rosa spring menu table with pasta, wine, and candlelight" />
      <div>
        <p class="eyebrow eyebrow--light">Seasonal Menu</p>
        <h1>Menu</h1>
        <p>Fresh pasta, small plates, and classic Italian mains for lunch, dinner, and pickup.</p>
        <div class="menu-actions">
          <a class="btn" href="/assets/menu.pdf">Download PDF</a>
          <a class="btn btn--light" href="/online-ordering">Order Pickup</a>
        </div>
      </div>
    </section>

    <section class="menu-intro">
      <p>{restaurant.address}</p>
      <p>Mon-Thu {restaurant.hours.monThu} · Fri-Sat {restaurant.hours.friSat} · Sun {restaurant.hours.sunday}</p>
    </section>

    <section class="menu-board" aria-label="Bella Rosa menu">
      {menuItems.map((category) => (
        <div class="menu-section">
          <div class="menu-section__heading">
            <p class="eyebrow">Bella Rosa</p>
            <h2>{category.section}</h2>
          </div>
          <div class="menu-items">
            {category.items.map((item) => (
              <article class="menu-row">
                <img src={item.image} alt={item.name} loading="lazy" />
                <div class="menu-row__content">
                  <div class="menu-title-row">
                    <h3>{item.name}</h3>
                    <strong>{item.price}</strong>
                  </div>
                  <p class="menu-copy">{item.description}</p>
                  <div class="menu-tags">
                    {item.tags.map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="menu-pdf-preview">
      <div>
        <p class="eyebrow">PDF Menu</p>
        <h2>Prefer a printable menu?</h2>
        <p>Download the current spring menu as a PDF.</p>
        <a class="btn btn--ghost" href="/assets/menu.pdf">Download PDF</a>
      </div>
      <a class="menu-pdf-cover" href="/assets/menu.pdf" aria-label="Download Bella Rosa PDF menu">
        <img src="/assets/generated/bella-menu-cover.png" alt="Bella Rosa menu cover with pasta and wine" loading="lazy" />
      </a>
    </section>
  </main>
</SiteLayout>
