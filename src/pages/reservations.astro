---
import SiteLayout from "../layouts/SiteLayout.astro";
import { restaurant } from "../data/site";
---

<SiteLayout
  title="Reservations | Bella Rosa Italian Kitchen"
  description="Reserve a table at Bella Rosa Italian Kitchen in Charlotte with our OpenTable booking form."
>
  <main class="content-band page-frame">
    <div class="section-heading">
      <p class="eyebrow">Reservations</p>
      <h1>Reservations</h1>
      <p class="hero-copy">
        Book through OpenTable or call the restaurant for larger parties.
      </p>
      <a class="btn" href={`tel:${restaurant.phone.replace(/\D/g, "")}`}>Call to reserve</a>
    </div>

    <section class="content-band">
      <iframe
        title="OpenTable Reservation Widget"
        src={restaurant.reservation.openTableWidgetUrl}
        class="reservation-widget"
        loading="lazy"
      ></iframe>
      <p class="hero-copy">
        If the widget does not load, use OpenTable directly:
        <a class="inline-link" href={restaurant.reservation.openTableButtonUrl} target="_blank" rel="noreferrer">
          OpenTable reservation page
        </a>
      </p>
    </section>
  </main>
</SiteLayout>
