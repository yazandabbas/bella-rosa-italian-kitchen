---
import SiteLayout from "../layouts/SiteLayout.astro";
import { featuredDishes, restaurant } from "../data/site";
---

<SiteLayout
  title="Bella Rosa Italian Kitchen | Charlotte, NC"
  description="Bella Rosa Italian Kitchen — neighborhood dining in Charlotte with reservations and pickup ordering."
>
  <main class="home-shell">
    <section class="visual-hero" aria-labelledby="home-title">
      <img
        class="visual-hero__image"
        src="/assets/generated/bella-hero.png"
        alt="Warm Bella Rosa dining room with Italian plates and candlelight"
      />
      <div class="visual-hero__content">
        <p class="eyebrow eyebrow--light">Charlotte Italian Kitchen</p>
        <h1 id="home-title">Bella Rosa Italian Kitchen</h1>
        <p>
          Handmade pasta, candlelit tables, pickup from Toast, and easy OpenTable reservations in the South End and
          Dilworth neighborhood.
        </p>
        <div class="hero-actions">
          <a class="btn" href="/reservations">Reserve a Table</a>
          <a class="btn btn--light" href="/online-ordering">Order Pickup</a>
        </div>
      </div>
      <div class="hero-hours">
        <strong>Open today</strong>
        <span>Mon-Thu {restaurant.hours.monThu}</span>
        <span>Fri-Sat {restaurant.hours.friSat}</span>
      </div>
    </section>

    <section class="action-strip" aria-label="Quick actions">
      <a href="/reservations">
        <span>01</span>
        <strong>Book a table</strong>
      </a>
      <a href="/online-ordering">
        <span>02</span>
        <strong>Order pickup</strong>
      </a>
      <a href={restaurant.links.googleMapsQuery} target="_blank" rel="noreferrer">
        <span>03</span>
        <strong>Get directions</strong>
      </a>
      <a href={restaurant.ordering.giftCardUrl}>
        <span>04</span>
        <strong>Gift cards</strong>
      </a>
    </section>

    <section class="image-story">
      <div>
        <p class="eyebrow">Spring Menu</p>
        <h2>Food that looks like dinner plans.</h2>
        <p>
          Seasonal Italian plates with enough polish for date night and enough warmth for a regular Tuesday table.
        </p>
        <a class="inline-link" href="/menu">Explore the menu</a>
      </div>
      <img src="/assets/generated/bella-tagliatelle.png" alt="Fresh tagliatelle with mushrooms and herbs" />
    </section>

    <section class="feature-grid content-band">
      {featuredDishes.map((dish) => (
        <article class="feature-card">
          <img src={dish.image} alt={dish.name} />
          <div>
            <p class="eyebrow">{dish.tags[0]}</p>
            <h3>{dish.name}</h3>
            <p>{dish.description}</p>
            <strong>{dish.price}</strong>
          </div>
        </article>
      ))}
    </section>

    <section class="split-band">
      <img src="/assets/generated/bella-catering.png" alt="Private dining table with Italian catering dishes" />
      <div>
        <p class="eyebrow">Private Dining</p>
        <h2>Family-style tables, finished beautifully.</h2>
        <p>
          Catering and private dining for anniversaries, office dinners, holiday hosting, and intimate celebrations.
        </p>
        <a class="btn btn--ghost" href="/catering">Plan Catering</a>
      </div>
    </section>

    <section class="review-band">
      <blockquote>
        "Cozy, attentive, and full of personality. You can feel the care in every course."
      </blockquote>
      <a class="inline-link" href="/reviews">Read guest reviews</a>
    </section>
  </main>
</SiteLayout>
