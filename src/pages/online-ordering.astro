---
import SiteLayout from "../layouts/SiteLayout.astro";
import { restaurant } from "../data/site";
---

<SiteLayout
  title="Online Ordering | Bella Rosa Italian Kitchen"
  description="Order pickup from Bella Rosa Italian Kitchen with Toast."
>
  <main class="content-band page-frame">
    <div class="section-heading">
      <p class="eyebrow">Online Ordering</p>
      <h1>Order pickup</h1>
      <p class="hero-copy">
        Place pickup orders through Toast.
      </p>
      <a class="btn" href={restaurant.ordering.toastUrl} target="_blank" rel="noreferrer">Order on Toast</a>
    </div>

    <section class="content-band">
      <h2>Pickup notes</h2>
      <div class="two-column-copy">
        <p>
          Choose a pickup time online. Call us for large orders or timing questions.
        </p>
        <p>
          For catering or group meals, send an inquiry before placing the order.
        </p>
      </div>
    </section>
  </main>
</SiteLayout>
