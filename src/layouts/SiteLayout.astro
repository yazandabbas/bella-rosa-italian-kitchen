---
import { restaurant } from "../data/site";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Menu", href: "/menu" },
  { label: "Reservations", href: "/reservations" },
  { label: "Online Ordering", href: "/online-ordering" },
  { label: "About Us", href: "/about" },
  { label: "Gallery", href: "/gallery" },
  { label: "Catering", href: "/catering" },
  { label: "Contact", href: "/contact" },
  { label: "Reviews", href: "/reviews" },
];

type Props = {
  title: string;
  description?: string;
};

const { title, description = `${restaurant.name} — Charlotte neighborhood Italian dining` } = Astro.props;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;

const announcement = {
  text: "New Spring menu arrives soon. Click here for opening-week tastings and early reservations.",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description}
    />
    <meta
      name="keywords"
      content={`${restaurant.seo.keywords}, ${restaurant.seo.city}, ${restaurant.seo.neighborhoods.join(", ")}, pizza`}
    />
    <meta name="theme-color" content="#2a1810" />
    <title>{title}</title>
    <link rel="icon" href="/assets/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="restaurant" />
    <meta property="og:url" content="https://bellarosakitchen.com" />
    <meta property="og:image" content="https://images.unsplash.com/photo-1516684732162-7b5f6f8f39c9?auto=format&fit=crop&w=1200&q=80" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="https://images.unsplash.com/photo-1516684732162-7b5f6f8f39c9?auto=format&fit=crop&w=1200&q=80"
    />
    <style is:global>
      @import "../styles/global.css";
    </style>
    {gaId ? <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script> : null}
    {gaId ? (
      <script is:inline>
        {`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${gaId}');
        `}
      </script>
    ) : null}
  </head>
  <body>
    <div class="announcement-root" id="announcement">
      <p>{announcement.text}</p>
      <button id="announcementDismiss" class="announcement-dismiss" aria-label="Dismiss announcement">×</button>
    </div>
    <div class="site-shell">
      <a href="/" class="skip-link">Skip to content</a>
      <header class="site-header">
        <a class="brand-mark" href="/" aria-label="Bella Rosa home">
          <span class="brand-mark__name">{restaurant.name}</span>
          <span class="brand-mark__eyebrow">Charlotte, NC</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <a class="header-cta" href={`tel:${restaurant.phone.replace(/\D/g, "")}`}>Call to reserve</a>
      </header>

      <slot />

      <footer class="site-footer">
        <div class="site-footer__content">
          <p>
            <strong>{restaurant.name}</strong>
          </p>
          <p>{restaurant.address}</p>
          <p>
            <a href={`mailto:${restaurant.email}`}>{restaurant.email}</a> •
            <a href={`tel:${restaurant.phone.replace(/\D/g, "")}`}>{restaurant.phone}</a>
          </p>
          <p>
            <a href="/reservations">Reservations</a> •
            <a href="/online-ordering">Order Online</a> •
            <a href={restaurant.ordering.giftCardUrl}>Gift Cards</a> •
            <a href={restaurant.links.instagram} target="_blank" rel="noreferrer">Instagram</a> •
            <a href={restaurant.links.facebook} target="_blank" rel="noreferrer">Facebook</a>
          </p>
        </div>
      </footer>
    </div>

    <script is:inline>
      (function () {
        const root = document.getElementById("announcement");
        const dismiss = document.getElementById("announcementDismiss");
        if (!root || !dismiss) return;
        const key = "bellaRosaAnnouncementDismissed";
        if (sessionStorage.getItem(key) === "1") {
          root.remove();
          return;
        }
        dismiss.addEventListener("click", () => {
          root.remove();
          sessionStorage.setItem(key, "1");
        });
      })();
    </script>
  </body>
</html>
